NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Agent service (apps/agent — FastAPI + LangGraph). Next forwards
# every chat turn to this URL. In dev: http://localhost:8001.
# In prod: the URL of your deployed agent service.
AGENT_BASE_URL=http://localhost:8001

# Note: LLM_PROVIDER, GEMINI_API_KEY, OPENAI_API_KEY now live in the
# agent service's own .env (apps/agent/.env), not here. Next no longer
# calls LLMs directly.
