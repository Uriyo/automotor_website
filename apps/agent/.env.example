# --- Agent service config ---
# Where this service listens.
AGENT_PORT=8001

# --- LLM provider ---
# One of: gemini | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key
OPENAI_API_KEY=your-openai-key

# --- Supabase (shared with the Next app) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret for verifying user tokens forwarded from Next.
# Found in Supabase → Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Checkpointing ---
# CHECKPOINT_BACKEND: sqlite | postgres
# - sqlite (default): zero-config local file, good for dev
# - postgres: production. Uses Supabase via Supavisor (Session Pooler)
#             OR a direct DB URL on hosts where IPv6 works.
CHECKPOINT_BACKEND=sqlite
CHECKPOINT_SQLITE_PATH=./checkpoints.sqlite
# Only required when CHECKPOINT_BACKEND=postgres.
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- CORS / trust ---
# Comma-separated origins allowed to call the agent. The Next app
# usually doesn't need this because it forwards server-side, but the
# browser might during local dev if you ever expose this directly.
ALLOWED_ORIGINS=http://localhost:3000
